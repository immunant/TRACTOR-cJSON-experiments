[22:06:45    14]     /* An array or object item will have a child pointer pointing to a chain of the items in the array/object. */
[22:06:45    14]     struct cJSON *child;
[22:06:45    14] 
[22:06:45    14]     /* The type of the item, as above. */
[22:06:45    14]     int type;
[22:06:45    14] 
[22:06:45    14]     /* The item's string, if type==cJSON_String  and type == cJSON_Raw */
[22:06:45    14]     char *valuestring;
